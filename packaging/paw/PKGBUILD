# Maintainer: skint007 <paw-repo.cyclic942@passmail.net>
pkgname=paw
pkgver=0.2.0
pkgrel=1
pkgdesc="Repo-scoped shortcut around yay/paru for the personal paw repo"
arch=('any')
url="https://github.com/skint007/paw"
license=('MIT')
depends=()
optdepends=('yay: AUR helper paw drives by default'
            'paru: alternative AUR helper for paw')
source=('paw' 'LICENSE')
sha256sums=('SKIP' 'SKIP')

package() {
  install -Dm755 "$srcdir/paw" "$pkgdir/usr/bin/paw"
  install -Dm644 "$srcdir/LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
