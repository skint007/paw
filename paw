#!/usr/bin/env bash
# paw — a thin, repo-scoped shortcut around an AUR helper (yay or paru) for the
# personal 'paw' repo. Everything below is plain pacman/AUR-helper syntax, so the
# helper's own output and behaviour are used as-is.
#
#   PAW_HELPER=paru paw …   force a specific helper (default: prefer yay, then paru)
#   PAW_REPO_NAME=…  paw …   point at a differently-named repo

REPO="${PAW_REPO_NAME:-paw}"

# Pick an AUR helper: honour $PAW_HELPER, else prefer yay, then fall back to paru.
HELPER="${PAW_HELPER:-}"
if [[ -z "$HELPER" ]]; then
  for h in yay paru; do
    command -v "$h" >/dev/null 2>&1 && { HELPER="$h"; break; }
  done
fi
if [[ -z "$HELPER" ]] || ! command -v "$HELPER" >/dev/null 2>&1; then
  echo "paw: needs an AUR helper — install yay or paru (or set PAW_HELPER)." >&2
  exit 1
fi

usage() {
  cat <<EOF
paw — shortcut for the '${REPO}' repo (via ${HELPER})

  paw                   list packages in the ${REPO} repo
  paw <pkg>...          install package(s) from ${REPO}
  paw search <term>     search the ${REPO} repo
  paw update            full system upgrade
  paw remove <pkg>...   uninstall package(s)
  paw info <pkg>        package details
  paw list              list ${REPO} packages
  paw -<flags> …        passthrough to ${HELPER} (e.g. paw -Ss term)

Override the helper with PAW_HELPER=paru (or yay).
EOF
}

# Prefix bare package names with "<repo>/" so installs target the paw repo.
scoped() { local p; for p in "$@"; do printf '%s/%s\n' "$REPO" "$p"; done; }

cmd="${1:-list}"; [[ $# -gt 0 ]] && shift
case "$cmd" in
  list|ls)             "$HELPER" -Sl "$REPO" ;;
  search|s)            if [[ $# -gt 0 ]]; then "$HELPER" -Sl "$REPO" | grep -i -- "$*"
                       else "$HELPER" -Sl "$REPO"; fi ;;
  update|up|upgrade)   "$HELPER" ;;
  remove|rm)           [[ $# -gt 0 ]] || { echo "usage: paw remove <pkg>..." >&2; exit 1; }
                       "$HELPER" -Rns "$@" ;;
  info)               [[ $# -gt 0 ]] || { echo "usage: paw info <pkg>" >&2; exit 1; }
                       "$HELPER" -Si "$REPO/$1" ;;
  install|i)           [[ $# -gt 0 ]] || { echo "usage: paw install <pkg>..." >&2; exit 1; }
                       mapfile -t pkgs < <(scoped "$@"); "$HELPER" -S "${pkgs[@]}" ;;
  help|-h|--help)      usage ;;
  -*)                  "$HELPER" "$cmd" "$@" ;;                       # raw passthrough
  *)                   mapfile -t pkgs < <(scoped "$cmd" "$@"); "$HELPER" -S "${pkgs[@]}" ;;
esac
